# .env.example — commit this to git (no real values)
# Copy to .env.local and fill in your values for local dev
# Set production values in your Netlify dashboard:
#   Dashboard → Your Site → Site Configuration → Environment Variables

# ─── Environment ─────────────────────────────────────────────
VITE_APP_ENV=dev
# Set to "prod" in Netlify environment variables

# ─── Contact ─────────────────────────────────────────────────
VITE_CONTACT_EMAIL=your_email@example.com

# ─── App ─────────────────────────────────────────────────────
VITE_APP_URL=https://your-site.netlify.app
