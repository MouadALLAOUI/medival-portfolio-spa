# ============================================
# Medieval Portfolio - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# Only VITE_* variables are exposed to the client.

# ---- App Environment ----
# Options: dev | prod
VITE_APP_ENV=dev

# ---- Contact Form ----
# Email address for the contact form
VITE_CONTACT_EMAIL=your-email@example.com

# ---- API Configuration ----
# Backend API URL (used for visitor tracking, etc.)
VITE_API_URL=http://localhost/medival-portfolio-apis/api

# Backend URL
VITE_BACKEND_URL=http://localhost/medival-portfolio

# API key for backend requests (set in hosting provider, not in .env)
VITE_API_KEY=

# ---- Server-Side Only (not accessible client-side) ----
# These are NOT Vite-prefixed and cannot be used in browser code.
# APP_ENV=local
# SITE_NAME=Medieval Portfolio
# SECRET_KEY=change_this_to_a_random_secure_string
# API_KEY=MEDIEVAL_API_KEY_12345
